{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Wiki Schema",
  "description": "知识图谱元数据定义",
  "definitions": {
    "Concept": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "概念唯一标识" },
        "name": { "type": "string", "description": "概念名称" },
        "aliases": { "type": "array", "items": { "type": "string" }, "description": "别名列表" },
        "category": { 
          "type": "string", 
          "enum": ["concept", "person", "project", "tool", "howto", "resource"]
        },
        "definition": { "type": "string", "description": "一句话定义" },
        "description": { "type": "string", "description": "详细描述" },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["related", "part_of", "used_by", "created_by"] },
              "target": { "type": "string", "description": "关联概念 ID" }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "来源文件路径列表"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "置信度"
        },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" }
      },
      "required": ["id", "name", "category"]
    }
  },
  "type": "object",
  "properties": {
    "concepts": {
      "type": "array",
      "items": { "$ref": "#/definitions/Concept" }
    },
    "version": { "type": "string" },
    "last_compiled": { "type": "string", "format": "date-time" }
  }
}
